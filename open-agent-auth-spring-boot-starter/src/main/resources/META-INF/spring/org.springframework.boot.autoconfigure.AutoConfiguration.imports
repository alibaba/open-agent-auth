# Open Agent Auth Auto-Configuration
# This file defines the order in which auto-configurations are loaded

# Core configuration (loaded first - provides shared beans like KeyManager)
com.alibaba.openagentauth.spring.autoconfigure.core.CoreAutoConfiguration

# JWE encryption configuration (loaded after core, conditional on open-agent-auth.encryption.enabled)
com.alibaba.openagentauth.spring.autoconfigure.role.JweEncryptionAutoConfiguration

# Role-specific configurations (loaded based on open-agent-auth.role property)
# Only one role should be enabled at a time in production
com.alibaba.openagentauth.spring.autoconfigure.role.AgentUserIdpAutoConfiguration
com.alibaba.openagentauth.spring.autoconfigure.role.AgentIdpAutoConfiguration
com.alibaba.openagentauth.spring.autoconfigure.role.AsUserIdpAutoConfiguration
com.alibaba.openagentauth.spring.autoconfigure.role.AuthorizationServerAutoConfiguration
com.alibaba.openagentauth.spring.autoconfigure.role.ResourceServerAutoConfiguration
com.alibaba.openagentauth.spring.autoconfigure.role.AgentAutoConfiguration

# OAuth2 Authorization configuration (loaded after role configs, provides AuthorizationOrchestrator)
com.alibaba.openagentauth.spring.config.OAuth2AuthorizationConfiguration

# Spring Web configuration (loaded last - scans for REST controllers with @ConditionalOnBean)
# Must be loaded after all role and config classes so that @ConditionalOnBean can detect registered beans
com.alibaba.openagentauth.spring.autoconfigure.SpringWebAutoConfiguration